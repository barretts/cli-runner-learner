{
  "name": "cli-runner-learner",
  "version": "0.3.0",
  "description": "Learn CLI tool behavior via PTY probing, then export skills and adapter presets for agentic automation",
  "license": "MIT",
  "author": "Barrett Sonntag",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clr": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "skill/",
    "compiled/",
    "profiles/_template.json",
    "profiles/agent.json",
    "profiles/agent-print.json",
    "profiles/claude.json",
    "profiles/claude-print.json",
    "profiles/crush.json",
    "profiles/crush-print.json",
    "profiles/gemini.json",
    "profiles/opencode.json",
    "adapter-overrides.json",
    "README.md",
    "LICENSE",
    "install-local.sh"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "postbuild": "node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run build && npm run smoke",
    "typecheck": "tsc --noEmit",
    "smoke": "node dist/cli.js --help >/dev/null",
    "test": "npm run smoke",
    "cli": "node dist/cli.js",
    "compile": "node skill/build/compile.mjs",
    "compile:validate": "node skill/build/compile.mjs --validate",
    "compile:watch": "node skill/build/compile.mjs --watch",
    "setup": "bash install-local.sh",
    "setup:skills": "bash install-local.sh --skills-only",
    "uninstall-skills": "bash install-local.sh --uninstall"
  },
  "keywords": [
    "cli",
    "automation",
    "agent",
    "llm",
    "pty",
    "tool",
    "state-machine",
    "interactive",
    "skill",
    "adapter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barretts/cli-runner-learner.git"
  },
  "homepage": "https://github.com/barretts/cli-runner-learner#readme",
  "bugs": {
    "url": "https://github.com/barretts/cli-runner-learner/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "typescript": "^5.7.3"
  }
}
