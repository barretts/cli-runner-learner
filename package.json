{
  "name": "cli-runner-learner",
  "version": "0.3.1",
  "description": "Learn CLI tool behavior via PTY probing, then export skills and adapter presets for agentic automation",
  "license": "MIT",
  "author": "Barrett Sonntag",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clr": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "compiled/",
    "profiles/_template.json",
    "profiles/agent.json",
    "profiles/agent-print.json",
    "profiles/claude.json",
    "profiles/claude-print.json",
    "profiles/crush.json",
    "profiles/crush-print.json",
    "profiles/gemini.json",
    "profiles/opencode.json",
    "adapter-overrides.json",
    "README.md",
    "LICENSE",
    "install-local.sh"
  ],
  "scripts": {
    "smoke": "node dist/cli.js --help >/dev/null",
    "test": "npm run smoke",
    "cli": "node dist/cli.js",
    "setup": "bash install-local.sh",
    "setup:skills": "bash install-local.sh --skills-only",
    "uninstall-skills": "bash install-local.sh --uninstall"
  },
  "keywords": [
    "cli",
    "automation",
    "agent",
    "llm",
    "pty",
    "tool",
    "state-machine",
    "interactive",
    "skill",
    "adapter"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barretts/cli-runner-learner.git"
  },
  "homepage": "https://github.com/barretts/cli-runner-learner#readme",
  "bugs": {
    "url": "https://github.com/barretts/cli-runner-learner/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "node-pty": "^1.1.0"
  }
}
